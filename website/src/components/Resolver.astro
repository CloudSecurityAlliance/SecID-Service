---
// Interactive SecID resolver — calls /api/v1/resolve and displays results
// Features: drill-down links, status badges, registry explorer
---

<div class="resolver">
  <form id="resolver-form" autocomplete="off">
    <label for="resolver-input">Resolve a SecID</label>
    <div class="resolver-row">
      <input
        id="resolver-input"
        type="text"
        placeholder="secid:advisory/mitre.org/cve#CVE-2021-44228"
        spellcheck="false"
      />
      <button type="submit">Resolve</button>
    </div>
    <div class="resolver-examples">
      Try:
      <button type="button" data-example="secid:advisory/mitre.org/cve#CVE-2021-44228">CVE</button>
      <button type="button" data-example="secid:weakness/mitre.org/cwe#CWE-79">CWE</button>
      <button type="button" data-example="secid:ttp/mitre.org/attack#T1059.003">ATT&CK</button>
      <button type="button" data-example="secid:advisory/CVE-2024-1234">Cross-source</button>
      <button type="button" data-example="secid:weakness">Browse weaknesses</button>
    </div>
    <div class="resolver-actions-row">
      <button type="button" id="explore-btn">Explore Registry</button>
      <a href="/api/v1/registry.json" download="secid-registry.json" class="registry-link">Download Registry JSON</a>
    </div>
  </form>
  <div id="resolver-output" class="resolver-output" hidden></div>
</div>

<style is:global>
  .resolver {
    margin: 2rem 0;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
  }
  .resolver label {
    display: block;
    font-weight: 600;
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }
  .resolver-row {
    display: flex;
    gap: 0.5rem;
  }
  .resolver-row input {
    flex: 1;
    padding: 0.6rem 0.8rem;
    font-size: 1rem;
    font-family: var(--font-mono);
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
    color: var(--fg);
  }
  .resolver-row input:focus {
    outline: 2px solid var(--accent);
    outline-offset: -1px;
  }
  .resolver-row button {
    padding: 0.6rem 1.2rem;
    font-size: 1rem;
    font-weight: 600;
    border: none;
    border-radius: 4px;
    background: var(--accent);
    color: #fff;
    cursor: pointer;
  }
  .resolver-row button:hover {
    opacity: 0.9;
  }
  .resolver-examples {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--fg-muted);
  }
  .resolver-examples button {
    background: none;
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.15rem 0.5rem;
    font-size: 0.8rem;
    color: var(--accent);
    cursor: pointer;
    margin-left: 0.25rem;
  }
  .resolver-examples button:hover {
    background: var(--accent);
    color: #fff;
  }
  .resolver-actions-row {
    margin-top: 0.75rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .resolver-actions-row button {
    background: none;
    border: 1px solid var(--accent);
    border-radius: 4px;
    padding: 0.4rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    cursor: pointer;
  }
  .resolver-actions-row button:hover {
    background: var(--accent);
    color: #fff;
  }
  .registry-link {
    font-size: 0.85rem;
    color: var(--accent);
    text-decoration: none;
  }
  .registry-link:hover {
    text-decoration: underline;
  }
  .resolver-output {
    position: relative;
    margin-top: 1rem;
    padding: 1rem 1rem 1rem 2.2rem;
    border-radius: 4px;
    background: var(--bg);
    border: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.5;
    overflow-x: auto;
    max-height: 400px;
    overflow-y: auto;
  }
  .resolver-output.explorer-active {
    max-height: none;
  }
  .output-close-btn {
    position: absolute;
    top: 0.4rem;
    left: 0.4rem;
    background: none;
    border: 1px solid var(--border);
    border-radius: 3px;
    width: 1.4rem;
    height: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    color: var(--fg-muted);
    cursor: pointer;
    line-height: 1;
    padding: 0;
  }
  .output-close-btn:hover {
    color: var(--red);
    border-color: var(--red);
  }

  /* Status badges */
  .status-badge {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    border-radius: 3px;
    font-size: 0.8rem;
    font-weight: 600;
  }
  .status-badge[data-status="found"] {
    background: var(--green);
    color: #fff;
  }
  .status-badge[data-status="corrected"] {
    background: var(--blue);
    color: #fff;
  }
  .status-badge[data-status="related"] {
    background: var(--yellow);
    color: #000;
  }
  .status-badge[data-status="not_found"],
  .status-badge[data-status="error"] {
    background: var(--red);
    color: #fff;
  }

  /* Result items */
  .result-item {
    position: relative;
    margin-top: 0.5rem;
    padding: 0.75rem 2.5rem 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--surface);
  }

  /* Copy buttons */
  .result-copy-btn,
  .copy-json-btn {
    background: none;
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.15rem 0.45rem;
    font-size: 0.7rem;
    color: var(--fg-muted);
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
  }
  .result-copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
  }
  .result-copy-btn:hover,
  .copy-json-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .result-copy-btn[data-copied],
  .copy-json-btn[data-copied] {
    color: var(--green);
    border-color: var(--green);
  }
  .copy-json-btn {
    margin-left: auto;
  }

  /* Drill-down links */
  .result-secid-link {
    color: var(--accent);
    cursor: pointer;
    text-decoration: none;
    border-bottom: 1px dashed var(--accent);
  }
  .result-secid-link:hover {
    border-bottom-style: solid;
  }

  /* Explorer styles */
  .explorer-breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 1rem;
    font-size: 0.85rem;
    flex-wrap: wrap;
  }
  .explorer-breadcrumbs span {
    color: var(--fg-muted);
  }
  .explorer-breadcrumbs a {
    color: var(--accent);
    cursor: pointer;
    text-decoration: none;
  }
  .explorer-breadcrumbs a:hover {
    text-decoration: underline;
  }
  .explorer-type-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: 0.75rem;
  }
  .explorer-type-card {
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface);
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .explorer-type-card:hover {
    border-color: var(--accent);
  }
  .explorer-type-card h4 {
    margin: 0 0 0.25rem;
    font-size: 0.95rem;
    color: var(--accent);
  }
  .explorer-type-card p {
    margin: 0;
    font-size: 0.8rem;
    color: var(--fg-muted);
    font-family: var(--font-sans, system-ui, sans-serif);
    line-height: 1.4;
  }
  .explorer-item {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    margin-bottom: 0.4rem;
    cursor: pointer;
    font-size: 0.85rem;
    color: var(--accent);
    transition: border-color 0.15s;
  }
  .explorer-item:hover {
    border-color: var(--accent);
  }
  .explorer-detail-section {
    margin-top: 0.75rem;
    padding: 0.75rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--surface);
  }
  .explorer-detail-section h4 {
    margin: 0 0 0.4rem;
    font-size: 0.85rem;
    color: var(--fg);
  }
  .explorer-detail-section p,
  .explorer-detail-section li {
    font-size: 0.8rem;
    color: var(--fg-muted);
    font-family: var(--font-sans, system-ui, sans-serif);
    line-height: 1.4;
  }
  .explorer-detail-section ul {
    margin: 0;
    padding-left: 1.2rem;
  }
</style>

<script>
  const form = document.getElementById("resolver-form") as HTMLFormElement;
  const input = document.getElementById("resolver-input") as HTMLInputElement;
  const output = document.getElementById("resolver-output") as HTMLDivElement;
  const exploreBtn = document.getElementById("explore-btn") as HTMLButtonElement;

  const DEFAULT_TITLE = document.title;

  // --- URL state management ---
  function updateURL(secid: string | null, replace = false): void {
    const url = new URL(window.location.href);
    if (secid) {
      url.searchParams.set("secid", secid);
    } else {
      url.searchParams.delete("secid");
    }
    if (replace) {
      history.replaceState(null, "", url.toString());
    } else {
      history.pushState(null, "", url.toString());
    }
  }

  async function resolveFromURL(secid: string): Promise<void> {
    output.hidden = false;
    output.textContent = "Resolving\u2026";
    try {
      const data = await fetchResolve(secid);
      renderResponse(output, data);
      document.title = `${secid} \u2014 SecID`;
    } catch (err) {
      output.textContent = `Error: ${(err as Error).message}`;
    }
  }

  window.addEventListener("popstate", () => {
    const params = new URLSearchParams(window.location.search);
    const secid = params.get("secid");
    if (secid) {
      input.value = secid;
      exitExplorerMode();
      resolveFromURL(secid);
    } else {
      input.value = "";
      output.hidden = true;
      output.textContent = "";
      exitExplorerMode();
      document.title = DEFAULT_TITLE;
    }
  });

  // --- Explorer state ---
  let explorerMode = false;
  let explorerPath: { label: string; secid: string | null }[] = [];

  const TYPE_DESCRIPTIONS: Record<string, string> = {
    advisory: "Vulnerability advisories, incident reports, and safety publications",
    capability: "Product security features — configurations, audit commands, remediation",
    control: "Security controls, frameworks, and benchmarks",
    disclosure: "Vulnerability disclosure programs, policies, and reporting channels",
    entity: "Vendors, products, and services",
    methodology: "Formal processes — scoring (CVSS, SSVC), mapping (IR 8477), risk assessment (ISO 27005), threat modeling (STRIDE)",
    reference: "Documents, research papers, and identifier systems",
    regulation: "Laws, directives, and legal requirements",
    ttp: "Attack patterns, adversary techniques, and procedures",
    weakness: "Weakness taxonomies and abstract flaw patterns",
  };

  // --- Example buttons fill the input and submit ---
  form.querySelectorAll("[data-example]").forEach((btn) => {
    btn.addEventListener("click", () => {
      input.value = (btn as HTMLElement).dataset.example!;
      exitExplorerMode();
      form.requestSubmit();
    });
  });

  // --- Form submit: resolve mode ---
  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const query = input.value.trim();
    if (!query) return;

    exitExplorerMode();
    updateURL(query);
    output.hidden = false;
    output.textContent = "Resolving\u2026";

    try {
      const data = await fetchResolve(query);
      renderResponse(output, data);
      document.title = `${query} \u2014 SecID`;
    } catch (err) {
      output.textContent = `Error: ${(err as Error).message}`;
    }
  });

  // --- Explore button ---
  exploreBtn.addEventListener("click", () => {
    explorerMode = true;
    explorerPath = [{ label: "Registry", secid: null }];
    output.hidden = false;
    updateURL(null);
    renderExplorerRoot();
  });

  // --- API helper ---
  async function fetchResolve(secid: string): Promise<ResolveResponse> {
    const url = `/api/v1/resolve?secid=${encodeURIComponent(secid)}`;
    const res = await fetch(url);
    return res.json();
  }

  // --- Close button helper ---
  function addCloseButton(container: HTMLElement): void {
    const btn = document.createElement("button");
    btn.className = "output-close-btn";
    btn.type = "button";
    btn.textContent = "\u00d7";
    btn.title = "Close";
    btn.addEventListener("click", () => {
      container.hidden = true;
      container.textContent = "";
      exitExplorerMode();
      updateURL(null, true);
      document.title = DEFAULT_TITLE;
    });
    container.appendChild(btn);
  }

  // --- Drill-down: set input and resolve ---
  function resolveAndRender(secid: string): void {
    input.value = secid;
    exitExplorerMode();
    form.requestSubmit();
  }

  function exitExplorerMode(): void {
    explorerMode = false;
    explorerPath = [];
    output.classList.remove("explorer-active");
  }

  // --- Copy button helper ---
  function createCopyButton(data: unknown, className = "result-copy-btn"): HTMLButtonElement {
    const btn = document.createElement("button");
    btn.type = "button";
    btn.className = className;
    btn.textContent = "Copy";
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(JSON.stringify(data, null, 2));
        btn.textContent = "Copied!";
        btn.dataset.copied = "";
        setTimeout(() => {
          btn.textContent = "Copy";
          delete btn.dataset.copied;
        }, 1500);
      } catch {
        btn.textContent = "Failed";
        setTimeout(() => { btn.textContent = "Copy"; }, 1500);
      }
    });
    return btn;
  }

  // --- Interfaces ---
  interface ResolveResult {
    secid: string;
    weight?: number;
    url?: string;
    data?: Record<string, unknown>;
  }

  interface ResolveResponse {
    secid_query: string;
    status: string;
    results: ResolveResult[];
    message?: string;
  }

  // --- Render resolver response ---
  function renderResponse(container: HTMLElement, data: ResolveResponse): void {
    container.textContent = "";
    addCloseButton(container);

    // Header row: status badge + query
    const header = document.createElement("div");
    header.style.display = "flex";
    header.style.alignItems = "center";
    header.style.flexWrap = "wrap";
    header.style.gap = "0.5rem";

    const badge = document.createElement("span");
    badge.className = "status-badge";
    badge.dataset.status = data.status;
    badge.textContent = data.status;
    header.appendChild(badge);

    const querySpan = document.createElement("span");
    querySpan.textContent = data.secid_query;
    header.appendChild(querySpan);

    container.appendChild(header);

    // Message if present
    if (data.message) {
      const msgLine = document.createElement("div");
      msgLine.textContent = data.message;
      msgLine.style.marginTop = "0.4rem";
      msgLine.style.color = "var(--fg-muted)";
      msgLine.style.fontFamily = "var(--font-sans, system-ui, sans-serif)";
      msgLine.style.fontSize = "0.85rem";
      container.appendChild(msgLine);
    }

    // Check if this is a type-level result (has data.namespaces array)
    if (data.results.length === 1 && data.results[0].data?.namespaces && Array.isArray(data.results[0].data.namespaces)) {
      const typeResult = data.results[0];
      const typeData = typeResult.data!;
      const namespaces = typeData.namespaces as Array<{namespace: string; official_name: string; common_name: string | null; source_count: number}>;

      // Type description
      if (typeData.description) {
        const descDiv = document.createElement("div");
        descDiv.textContent = typeData.description as string;
        descDiv.style.color = "var(--fg-muted)";
        descDiv.style.fontFamily = "var(--font-sans, system-ui, sans-serif)";
        descDiv.style.fontSize = "0.85rem";
        descDiv.style.margin = "0.5rem 0";
        container.appendChild(descDiv);
      }

      // Purpose
      if (typeData.purpose) {
        const purposeDiv = document.createElement("div");
        purposeDiv.textContent = typeData.purpose as string;
        purposeDiv.style.color = "var(--fg-muted)";
        purposeDiv.style.fontFamily = "var(--font-sans, system-ui, sans-serif)";
        purposeDiv.style.fontSize = "0.8rem";
        purposeDiv.style.margin = "0.25rem 0 0.75rem";
        container.appendChild(purposeDiv);
      }

      // Count
      const nsCountLine = document.createElement("div");
      nsCountLine.textContent = `${namespaces.length} namespaces`;
      nsCountLine.style.color = "var(--fg-muted)";
      nsCountLine.style.fontSize = "0.8rem";
      nsCountLine.style.marginBottom = "0.5rem";
      container.appendChild(nsCountLine);

      // Render each namespace as a clickable item
      for (const ns of namespaces) {
        const item = document.createElement("div");
        item.className = "explorer-item";

        const nameSpan = document.createElement("span");
        nameSpan.style.fontWeight = "600";
        nameSpan.textContent = ns.namespace;
        item.appendChild(nameSpan);

        if (ns.official_name) {
          const nameInfo = document.createElement("span");
          nameInfo.style.color = "var(--fg-muted)";
          nameInfo.style.marginLeft = "0.5rem";
          nameInfo.style.fontFamily = "var(--font-sans, system-ui, sans-serif)";
          nameInfo.textContent = `— ${ns.official_name}`;
          if (ns.source_count > 1) {
            nameInfo.textContent += ` (${ns.source_count} sources)`;
          }
          item.appendChild(nameInfo);
        }

        // Extract type from the secid
        const typeStr = typeResult.secid.replace(/^secid:/, "");
        const drillSecid = `secid:${typeStr}/${ns.namespace}`;
        item.addEventListener("click", () => resolveAndRender(drillSecid));
        container.appendChild(item);
      }

      // Examples section
      if (typeData.examples && Array.isArray(typeData.examples) && (typeData.examples as string[]).length > 0) {
        const exSection = document.createElement("div");
        exSection.style.marginTop = "0.75rem";
        exSection.style.paddingTop = "0.5rem";
        exSection.style.borderTop = "1px solid var(--border)";

        const exLabel = document.createElement("div");
        exLabel.textContent = "Examples:";
        exLabel.style.fontSize = "0.8rem";
        exLabel.style.fontWeight = "600";
        exLabel.style.marginBottom = "0.25rem";
        exSection.appendChild(exLabel);

        for (const ex of typeData.examples as string[]) {
          const exItem = document.createElement("div");
          const exLink = document.createElement("a");
          exLink.className = "result-secid-link";
          exLink.textContent = ex;
          exLink.style.fontSize = "0.8rem";
          exLink.addEventListener("click", (e) => {
            e.preventDefault();
            resolveAndRender(ex);
          });
          exItem.appendChild(exLink);
          exSection.appendChild(exItem);
        }

        container.appendChild(exSection);
      }

      return; // Don't fall through to normal result rendering
    }

    if (data.results && data.results.length > 0) {
      const countLine = document.createElement("div");
      countLine.textContent = `${data.results.length} result${data.results.length !== 1 ? "s" : ""}`;
      countLine.style.marginTop = "0.5rem";
      countLine.style.color = "var(--fg-muted)";
      countLine.style.fontSize = "0.8rem";
      container.appendChild(countLine);

      for (const r of data.results) {
        const item = document.createElement("div");
        item.className = "result-item";

        // Copy button (top-right) — copies compact JSON for this result
        const copyData: Record<string, unknown> = { secid: r.secid };
        if (r.weight != null) copyData.weight = r.weight;
        if (r.url) copyData.url = r.url;
        if (r.data) copyData.data = r.data;
        item.appendChild(createCopyButton(copyData));

        // SecID line — clickable for drill-down when browsing registry results
        const secidLine = document.createElement("div");
        const isRegistryBrowse = !r.url && r.data;
        if (isRegistryBrowse) {
          const link = document.createElement("a");
          link.className = "result-secid-link";
          link.textContent = r.secid;
          link.addEventListener("click", (e) => {
            e.preventDefault();
            resolveAndRender(r.secid);
          });
          secidLine.appendChild(link);
        } else {
          secidLine.textContent = r.secid;
        }
        if (r.weight != null) {
          const weightSpan = document.createElement("span");
          weightSpan.textContent = `  (weight: ${r.weight})`;
          weightSpan.style.color = "var(--fg-muted)";
          secidLine.appendChild(weightSpan);
        }
        item.appendChild(secidLine);

        // URL as clickable link
        if (r.url) {
          const urlLine = document.createElement("div");
          const link = document.createElement("a");
          link.href = r.url;
          link.textContent = r.url;
          link.target = "_blank";
          link.rel = "noopener";
          link.style.color = "var(--accent)";
          link.style.fontSize = "0.8rem";
          link.style.wordBreak = "break-all";
          urlLine.appendChild(link);
          item.appendChild(urlLine);
        }

        // Registry data fields — show all useful data
        if (r.data) {
          const d = r.data;

          // Text fields: render labeled lines for known fields
          const textFields: Array<[string, string | undefined]> = [
            ["Name", d.official_name as string | undefined],
            ["Common", d.common_name as string | undefined],
          ];
          for (const [label, val] of textFields) {
            if (!val) continue;
            const line = document.createElement("div");
            line.textContent = `${label}: ${val}`;
            line.style.fontSize = "0.8rem";
            item.appendChild(line);
          }

          // Description/notes/scope — grey sans-serif body text
          const bodyFields: Array<[string | null, string | undefined]> = [
            [null, d.description as string | undefined],
            ["Scope", d.scope as string | undefined],
            [null, d.note as string | undefined],
            [null, d.notes as string | undefined],
          ];
          for (const [label, val] of bodyFields) {
            if (!val) continue;
            const line = document.createElement("div");
            line.textContent = label ? `${label}: ${val}` : val;
            line.style.color = "var(--fg-muted)";
            line.style.fontSize = "0.8rem";
            line.style.fontFamily = "var(--font-sans, system-ui, sans-serif)";
            line.style.marginTop = "0.25rem";
            item.appendChild(line);
          }

          // URLs — render as clickable links
          if (d.urls && Array.isArray(d.urls)) {
            for (const u of d.urls as Array<{url: string; note?: string; type?: string}>) {
              const urlDiv = document.createElement("div");
              urlDiv.style.marginTop = "0.2rem";
              const link = document.createElement("a");
              link.href = u.url;
              link.target = "_blank";
              link.rel = "noopener";
              link.style.color = "var(--accent)";
              link.style.fontSize = "0.8rem";
              link.style.wordBreak = "break-all";
              link.textContent = u.note || u.url;
              urlDiv.appendChild(link);
              if (u.note) {
                const urlSpan = document.createElement("span");
                urlSpan.textContent = ` — ${u.url}`;
                urlSpan.style.fontSize = "0.75rem";
                urlSpan.style.color = "var(--fg-muted)";
                urlSpan.style.wordBreak = "break-all";
                urlDiv.appendChild(urlSpan);
              }
              item.appendChild(urlDiv);
            }
          }

          // Contacts (disclosure entries)
          if (d.contacts && Array.isArray(d.contacts)) {
            for (const c of d.contacts as Array<{type: string; value: string; note?: string}>) {
              const cDiv = document.createElement("div");
              cDiv.style.marginTop = "0.2rem";
              cDiv.style.fontSize = "0.8rem";
              if (c.type === "email") {
                const link = document.createElement("a");
                link.href = `mailto:${c.value}`;
                link.style.color = "var(--accent)";
                link.textContent = c.value;
                cDiv.appendChild(link);
                if (c.note) {
                  const noteSpan = document.createElement("span");
                  noteSpan.textContent = ` — ${c.note}`;
                  noteSpan.style.color = "var(--fg-muted)";
                  cDiv.appendChild(noteSpan);
                }
              } else if (c.type === "web") {
                const link = document.createElement("a");
                link.href = c.value;
                link.target = "_blank";
                link.rel = "noopener";
                link.style.color = "var(--accent)";
                link.style.wordBreak = "break-all";
                link.textContent = c.note || c.value;
                cDiv.appendChild(link);
              } else {
                cDiv.textContent = `${c.type}: ${c.value}${c.note ? ` — ${c.note}` : ""}`;
                cDiv.style.color = "var(--fg-muted)";
              }
              item.appendChild(cDiv);
            }
          }

          // Patterns (child patterns available)
          if (d.patterns && Array.isArray(d.patterns)) {
            const pDiv = document.createElement("div");
            pDiv.style.marginTop = "0.4rem";
            pDiv.style.fontSize = "0.8rem";
            pDiv.style.color = "var(--fg-muted)";
            pDiv.style.fontFamily = "var(--font-sans, system-ui, sans-serif)";
            const patLabel = document.createElement("span");
            patLabel.textContent = "Patterns: ";
            patLabel.style.fontWeight = "600";
            pDiv.appendChild(patLabel);
            for (const p of d.patterns as Array<{pattern: string; description: string}>) {
              const pLine = document.createElement("div");
              pLine.style.marginLeft = "1rem";
              pLine.textContent = `${p.description}`;
              pDiv.appendChild(pLine);
            }
            item.appendChild(pDiv);
          }

          // Examples
          if (d.examples && Array.isArray(d.examples) && (d.examples as unknown[]).length > 0) {
            const exDiv = document.createElement("div");
            exDiv.style.marginTop = "0.3rem";
            exDiv.style.fontSize = "0.8rem";
            exDiv.style.color = "var(--fg-muted)";
            const exLabel = document.createElement("span");
            exLabel.textContent = "Examples: ";
            exLabel.style.fontWeight = "600";
            exDiv.appendChild(exLabel);
            const exText = (d.examples as unknown[]).map(e => typeof e === "string" ? e : (e as {input?: string}).input || JSON.stringify(e)).join(", ");
            exDiv.appendChild(document.createTextNode(exText));
            item.appendChild(exDiv);
          }

          // Remaining data fields not yet rendered — show as key: value
          const rendered = new Set(["official_name", "common_name", "description", "scope", "note", "notes", "urls", "contacts", "patterns", "examples", "weight", "source_count", "child_count"]);
          for (const [key, val] of Object.entries(d)) {
            if (rendered.has(key) || val == null) continue;
            if (typeof val === "object") continue; // skip complex objects
            const line = document.createElement("div");
            line.textContent = `${key}: ${val}`;
            line.style.fontSize = "0.75rem";
            line.style.color = "var(--fg-muted)";
            line.style.marginTop = "0.1rem";
            item.appendChild(line);
          }
        }

        container.appendChild(item);
      }
    } else {
      const noResults = document.createElement("div");
      noResults.textContent = "No results.";
      noResults.style.marginTop = "0.5rem";
      container.appendChild(noResults);
    }
  }

  // --- Explorer: root view (7 type cards) ---
  function renderExplorerRoot(): void {
    output.textContent = "";
    output.classList.add("explorer-active");
    addCloseButton(output);

    // Breadcrumbs
    output.appendChild(renderBreadcrumbs());

    // Type grid
    const grid = document.createElement("div");
    grid.className = "explorer-type-grid";

    for (const [type, desc] of Object.entries(TYPE_DESCRIPTIONS)) {
      const card = document.createElement("div");
      card.className = "explorer-type-card";
      card.addEventListener("click", () => navigateExplorer(`secid:${type}`, type));

      const h4 = document.createElement("h4");
      h4.textContent = type;
      card.appendChild(h4);

      const p = document.createElement("p");
      p.textContent = desc;
      card.appendChild(p);

      grid.appendChild(card);
    }

    output.appendChild(grid);
  }

  // --- Explorer: navigate to a secid level ---
  async function navigateExplorer(secid: string, label: string): Promise<void> {
    explorerPath.push({ label, secid });
    output.textContent = "";
    output.hidden = false;
    output.classList.remove("explorer-active");
    updateURL(secid);
    document.title = `${secid} \u2014 SecID`;

    const loadingDiv = document.createElement("div");
    loadingDiv.textContent = "Loading\u2026";
    output.appendChild(loadingDiv);

    try {
      const data = await fetchResolve(secid);
      output.textContent = "";
      addCloseButton(output);

      // Breadcrumbs + Copy JSON
      const navRow = renderBreadcrumbs();
      navRow.appendChild(createCopyButton(data, "copy-json-btn"));
      output.appendChild(navRow);

      // Check if this is a type-level response (single result with namespaces array)
      if (data.results.length === 1 && data.results[0].data?.namespaces && Array.isArray(data.results[0].data.namespaces)) {
        const typeResult = data.results[0];
        const typeData = typeResult.data!;
        const namespaces = typeData.namespaces as Array<{namespace: string; official_name: string; common_name: string | null; source_count: number}>;

        if (typeData.description) {
          const descDiv = document.createElement("div");
          descDiv.textContent = typeData.description as string;
          descDiv.style.color = "var(--fg-muted)";
          descDiv.style.fontFamily = "var(--font-sans, system-ui, sans-serif)";
          descDiv.style.fontSize = "0.85rem";
          descDiv.style.margin = "0.5rem 0";
          output.appendChild(descDiv);
        }

        const nsCountLine = document.createElement("div");
        nsCountLine.textContent = `${namespaces.length} namespaces`;
        nsCountLine.style.color = "var(--fg-muted)";
        nsCountLine.style.fontSize = "0.8rem";
        nsCountLine.style.marginBottom = "0.5rem";
        output.appendChild(nsCountLine);

        const typeStr = typeResult.secid.replace(/^secid:/, "");
        for (const ns of namespaces) {
          const item = document.createElement("div");
          item.className = "explorer-item";

          const nameSpan = document.createElement("span");
          nameSpan.style.fontWeight = "600";
          nameSpan.textContent = ns.namespace;
          item.appendChild(nameSpan);

          if (ns.official_name) {
            const nameInfo = document.createElement("span");
            nameInfo.style.color = "var(--fg-muted)";
            nameInfo.style.marginLeft = "0.5rem";
            nameInfo.style.fontFamily = "var(--font-sans, system-ui, sans-serif)";
            nameInfo.textContent = `\u2014 ${ns.official_name}`;
            if (ns.source_count > 1) {
              nameInfo.textContent += ` (${ns.source_count} sources)`;
            }
            item.appendChild(nameInfo);
          }

          const drillSecid = `secid:${typeStr}/${ns.namespace}`;
          item.addEventListener("click", () => navigateExplorer(drillSecid, ns.namespace));
          output.appendChild(item);
        }
      } else if (data.results && data.results.length > 0) {
        for (const r of data.results) {
          // Determine if this result can be drilled deeper
          // Prevent self-referencing loops: if r.secid matches what we queried, it's a leaf
          const hasChildren = !r.url && r.data && r.secid !== secid;

          if (hasChildren) {
            // Clickable item for further navigation
            const item = document.createElement("div");
            item.className = "explorer-item";

            const nameSpan = document.createElement("span");
            nameSpan.style.fontWeight = "600";
            // Extract the meaningful part for the label
            const parts = r.secid.replace(/^secid:/, "").split("/");
            const shortLabel = parts[parts.length - 1] || r.secid;
            nameSpan.textContent = shortLabel;
            item.appendChild(nameSpan);

            if (r.data?.official_name || r.data?.common_name) {
              const nameInfo = document.createElement("span");
              nameInfo.style.color = "var(--fg-muted)";
              nameInfo.style.marginLeft = "0.5rem";
              nameInfo.style.fontFamily = "var(--font-sans, system-ui, sans-serif)";
              nameInfo.textContent = `\u2014 ${r.data.official_name || r.data.common_name}`;
              item.appendChild(nameInfo);
            }

            if (r.data?.description) {
              const desc = document.createElement("div");
              desc.textContent = r.data.description as string;
              desc.style.fontSize = "0.75rem";
              desc.style.color = "var(--fg-muted)";
              desc.style.fontFamily = "var(--font-sans, system-ui, sans-serif)";
              desc.style.marginTop = "0.2rem";
              item.appendChild(desc);
            }

            item.addEventListener("click", () => navigateExplorer(r.secid, shortLabel));
            output.appendChild(item);
          } else {
            // Leaf node: show as detail card
            const detail = document.createElement("div");
            detail.className = "explorer-detail-section";

            const h4 = document.createElement("h4");
            h4.textContent = r.secid;
            detail.appendChild(h4);

            if (r.url) {
              const urlDiv = document.createElement("div");
              const link = document.createElement("a");
              link.href = r.url;
              link.textContent = r.url;
              link.target = "_blank";
              link.rel = "noopener";
              link.style.color = "var(--accent)";
              link.style.fontSize = "0.8rem";
              link.style.wordBreak = "break-all";
              urlDiv.appendChild(link);
              detail.appendChild(urlDiv);
            }

            if (r.data) {
              const d = r.data;
              if (d.official_name || d.common_name) {
                const p = document.createElement("p");
                p.textContent = `${d.official_name || d.common_name}`;
                detail.appendChild(p);
              }
              if (d.description) {
                const p = document.createElement("p");
                p.textContent = d.description as string;
                detail.appendChild(p);
              }
              if (d.examples && Array.isArray(d.examples)) {
                const exH4 = document.createElement("h4");
                exH4.textContent = "Examples";
                exH4.style.marginTop = "0.5rem";
                detail.appendChild(exH4);
                const ul = document.createElement("ul");
                for (const ex of d.examples) {
                  const li = document.createElement("li");
                  li.textContent = typeof ex === "string" ? ex : JSON.stringify(ex);
                  ul.appendChild(li);
                }
                detail.appendChild(ul);
              }
            }

            output.appendChild(detail);
          }
        }
      } else {
        const noResults = document.createElement("div");
        noResults.textContent = data.message || "No results at this level.";
        noResults.style.color = "var(--fg-muted)";
        output.appendChild(noResults);
      }
    } catch (err) {
      output.textContent = `Error: ${(err as Error).message}`;
    }
  }

  // --- Breadcrumbs ---
  function renderBreadcrumbs(): HTMLElement {
    const nav = document.createElement("div");
    nav.className = "explorer-breadcrumbs";

    for (let i = 0; i < explorerPath.length; i++) {
      const crumb = explorerPath[i];
      const isLast = i === explorerPath.length - 1;

      if (i > 0) {
        const sep = document.createElement("span");
        sep.textContent = " / ";
        nav.appendChild(sep);
      }

      if (isLast) {
        const span = document.createElement("span");
        span.textContent = crumb.label;
        span.style.color = "var(--fg)";
        span.style.fontWeight = "600";
        nav.appendChild(span);
      } else {
        const link = document.createElement("a");
        link.textContent = crumb.label;
        const targetIndex = i;
        link.addEventListener("click", (e) => {
          e.preventDefault();
          // Trim path back to this level
          explorerPath = explorerPath.slice(0, targetIndex + 1);
          if (targetIndex === 0) {
            updateURL(null);
            renderExplorerRoot();
          } else {
            // Re-navigate to this crumb's secid
            explorerPath.pop(); // navigateExplorer will re-push it
            navigateExplorer(crumb.secid!, crumb.label);
          }
        });
        nav.appendChild(link);
      }
    }

    return nav;
  }

  // --- Auto-resolve from URL on page load ---
  (function autoResolveOnLoad() {
    const params = new URLSearchParams(window.location.search);
    const secid = params.get("secid");
    if (secid) {
      input.value = secid;
      resolveFromURL(secid);
    }
  })();
</script>
