---
import Resolver from "../components/Resolver.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A universal grammar for referencing security knowledge" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style is:global>
      :root {
        --font-sans: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        --font-mono: "SF Mono", "Fira Code", "Fira Mono", "Roboto Mono", monospace;
        --bg: #0f1117;
        --surface: #1a1d27;
        --border: #2a2d3a;
        --fg: #e4e4e7;
        --fg-muted: #9ca3af;
        --accent: #3b82f6;
        --green: #22c55e;
        --yellow: #eab308;
        --blue: #60a5fa;
        --red: #ef4444;
      }
      @media (prefers-color-scheme: light) {
        :root {
          --bg: #ffffff;
          --surface: #f8f9fa;
          --border: #d1d5db;
          --fg: #1f2937;
          --fg-muted: #6b7280;
          --accent: #2563eb;
          --green: #16a34a;
          --yellow: #ca8a04;
          --blue: #2563eb;
          --red: #dc2626;
        }
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { font-family: var(--font-sans); background: var(--bg); color: var(--fg); }
      body { min-height: 100vh; display: flex; flex-direction: column; }
      a { color: var(--accent); }
      code, pre { font-family: var(--font-mono); }
      code {
        background: var(--surface);
        padding: 0.15rem 0.35rem;
        border-radius: 3px;
        font-size: 0.9em;
      }
      pre {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 1rem;
        overflow-x: auto;
        font-size: 0.85rem;
        line-height: 1.6;
      }
      pre code {
        background: none;
        padding: 0;
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <div class="nav-inner">
          <a href="/" class="nav-brand">
            <img src="/csa-logo.jpeg" alt="Cloud Security Alliance" class="nav-logo" />
            SecID
          </a>
          <div class="nav-links">
            <a href="https://github.com/CloudSecurityAlliance/SecID" target="_blank" rel="noopener">Spec &amp; Registry</a>
            <a href="https://github.com/CloudSecurityAlliance/SecID-Service" target="_blank" rel="noopener">API Source</a>
          </div>
        </div>
      </nav>
    </header>
    <main>
      <div class="container">
        <Resolver />
        <slot />
      </div>
    </main>
    <footer>
      <div class="container">
        <p>SecID is a <a href="https://cloudsecurityalliance.org" target="_blank" rel="noopener">Cloud Security Alliance</a> project. <a href="https://github.com/CloudSecurityAlliance/SecID" target="_blank" rel="noopener">Contribute on GitHub</a>.</p>
      </div>
    </footer>
    <style>
      nav {
        border-bottom: 1px solid var(--border);
        background: var(--surface);
      }
      .nav-inner {
        max-width: 52rem;
        margin: 0 auto;
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .nav-brand {
        font-weight: 700;
        font-size: 1.25rem;
        text-decoration: none;
        color: var(--fg);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .nav-logo {
        height: 48px;
        width: auto;
      }
      .nav-links {
        display: flex;
        gap: 1.25rem;
        font-size: 0.9rem;
      }
      .container {
        max-width: 52rem;
        margin: 0 auto;
        padding: 0 1.5rem;
      }
      main {
        flex: 1;
        padding: 2rem 0;
      }
      footer {
        border-top: 1px solid var(--border);
        padding: 1.5rem 0;
        font-size: 0.85rem;
        color: var(--fg-muted);
      }
      .footer-inner {
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      .footer-logo {
        height: 28px;
        width: auto;
      }
      .footer-logo-link {
        flex-shrink: 0;
      }
    </style>
  </body>
</html>
